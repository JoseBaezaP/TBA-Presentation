---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import claudeWorking from '../assets/cluade-working.png';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Inicio" description="HEB-Automata: automatización inteligente del ciclo de desarrollo de software mediante agentes especializados de IA.">

  <!-- ===== HERO ===== -->
  <section class="relative bg-gradient-to-br from-blue-950 via-blue-900 to-slate-900 pt-28 pb-24 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-emerald-500/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-blue-400/10 rounded-full blur-3xl"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl">
        <p class="text-emerald-400 text-sm font-semibold uppercase tracking-widest mb-5">
          Sistema de Automatización del Ciclo de Desarrollo de Software
        </p>
        <h1 class="text-7xl font-black text-white mb-6 tracking-tight leading-none">
          HEB-Automata
        </h1>
        <p class="text-2xl text-blue-100 font-medium mb-6 leading-snug">
          Del requerimiento al código en producción,<br />orquestado automáticamente con Inteligencia Artificial.
        </p>
        <p class="text-slate-300 text-lg leading-relaxed mb-10 max-w-3xl">
          HEB-Automata es un ecosistema de agentes especializados que automatiza el ciclo completo de
          desarrollo de software: análisis de iniciativas, planificación arquitectónica, implementación
          de código, generación de documentación técnica e integración con Azure DevOps, todo desde
          un único punto de entrada.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href={`${base}/orquestador`} class="bg-emerald-500 hover:bg-emerald-600 text-white font-semibold px-8 py-4 rounded-xl transition-all duration-200 shadow-xl shadow-emerald-500/30 hover:-translate-y-0.5">
            Explorar el Sistema
          </a>
          <a href={`${base}/flujo-sdd`} class="bg-white/10 hover:bg-white/20 text-white font-semibold px-8 py-4 rounded-xl transition-all duration-200 border border-white/20">
            Ver Flujo SDD &rarr;
          </a>
        </div>
      </div>

      <!-- Imagen principal del sistema -->
      <div class="mt-16 rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-blue-950/50">
        <Image
          src={claudeWorking}
          alt="Claude Code ejecutando el flujo SDD con el orquestador HEB-Automata"
          class="w-full object-cover"
        />
      </div>
    </div>
  </section>

  <!-- ===== MÉTRICAS ===== -->
  <section class="bg-blue-950 border-b border-blue-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-8 text-center divide-x divide-blue-900">
        <div class="px-4">
          <div class="text-5xl font-black text-white mb-1">8</div>
          <div class="text-xs text-slate-400 uppercase tracking-wide">Agentes Especializados</div>
        </div>
        <div class="px-4">
          <div class="text-5xl font-black text-white mb-1">13</div>
          <div class="text-xs text-slate-400 uppercase tracking-wide">Skills de Automatización</div>
        </div>
        <div class="px-4">
          <div class="text-5xl font-black text-white mb-1">3</div>
          <div class="text-xs text-slate-400 uppercase tracking-wide">Plataformas de IA</div>
        </div>
        <div class="px-4">
          <div class="text-4xl font-black text-emerald-400 mb-1">A+B</div>
          <div class="text-xs text-slate-400 uppercase tracking-wide">Tracks en Paralelo</div>
        </div>
        <div class="px-4">
          <div class="text-4xl font-black text-emerald-400 mb-1">100%</div>
          <div class="text-xs text-slate-400 uppercase tracking-wide">Trazabilidad Git→Azure</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ¿QUÉ ES? ===== -->
  <section class="bg-white py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-emerald-600 text-sm font-semibold uppercase tracking-widest mb-4">Propósito</p>
          <h2 class="text-4xl font-black text-slate-900 mb-6 tracking-tight">¿Qué es HEB-Automata?</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            HEB-Automata es una solución de automatización integral que instala un ecosistema completo de
            agentes de inteligencia artificial en el asistente de desarrollo preferido del equipo
            (Claude Code, OpenCode o GitHub Copilot).
          </p>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Una vez instalado, el sistema es capaz de ejecutar el flujo <strong class="text-slate-900">SDD
            (Software Development Driven)</strong> de forma autónoma: desde la lectura e interpretación de un PRD
            hasta la creación de work items en Azure DevOps, la implementación del código con pruebas,
            y la generación de documentación técnica formal.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            El orquestador principal coordina a ocho agentes especializados que trabajan en paralelo,
            validando la consistencia en cada etapa mediante un sistema de <em>gates</em> que detecta
            ambigüedades, inconsistencias arquitectónicas y criterios faltantes antes de proceder.
          </p>
        </div>
        <div class="space-y-4">
          <div class="bg-slate-50 border border-slate-200 rounded-2xl p-6">
            <div class="flex items-center gap-4 mb-3">
              <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center text-lg">📋</div>
              <h3 class="font-bold text-slate-900">Análisis Automático de PRDs</h3>
            </div>
            <p class="text-slate-600 text-sm leading-relaxed">Lee PDFs, Markdown o texto plano y extrae requerimientos estructurados con escenarios Gherkin validados.</p>
          </div>
          <div class="bg-slate-50 border border-slate-200 rounded-2xl p-6">
            <div class="flex items-center gap-4 mb-3">
              <div class="w-10 h-10 bg-emerald-100 rounded-xl flex items-center justify-center text-lg">⚙️</div>
              <h3 class="font-bold text-slate-900">Implementación con Pruebas</h3>
            </div>
            <p class="text-slate-600 text-sm leading-relaxed">Genera código de producción y pruebas unitarias respetando la arquitectura existente del proyecto.</p>
          </div>
          <div class="bg-slate-50 border border-slate-200 rounded-2xl p-6">
            <div class="flex items-center gap-4 mb-3">
              <div class="w-10 h-10 bg-sky-100 rounded-xl flex items-center justify-center text-lg">🔗</div>
              <h3 class="font-bold text-slate-900">Integración Azure DevOps</h3>
            </div>
            <p class="text-slate-600 text-sm leading-relaxed">Crea la jerarquía completa Epic → Feature → HU → Tasks y vincula commits al trabajo documentado.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROBLEMA / SOLUCIÓN ===== -->
  <section class="bg-slate-50 py-24 border-y border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-emerald-600 text-sm font-semibold uppercase tracking-widest mb-4">Impacto</p>
        <h2 class="text-4xl font-black text-slate-900 mb-4 tracking-tight">El reto que resuelve</h2>
        <p class="text-slate-600 text-lg max-w-2xl mx-auto">
          El proceso de desarrollo de software implica múltiples pasos manuales, repetitivos y propensos a error.
          HEB-Automata los automatiza de forma inteligente.
        </p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Sin Automata -->
        <div class="bg-white border border-red-200 rounded-2xl p-8">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-8 h-8 bg-red-100 rounded-lg flex items-center justify-center">
              <span class="text-red-600 font-bold text-sm">✕</span>
            </div>
            <h3 class="text-xl font-bold text-slate-900">Sin HEB-Automata</h3>
          </div>
          <ul class="space-y-4">
            {[
              'Documentación técnica (TR.md, IFAO) redactada manualmente con alto costo de tiempo.',
              'Work items de Azure DevOps creados uno a uno sin estructura consistente.',
              'Revisión arquitectónica informal y dependiente del criterio individual.',
              'Escenarios Gherkin desconectados del código de pruebas.',
              'Trazabilidad commit–historia de usuario difícil de mantener.',
              'Sin reanudación de sesión: si el proceso se interrumpe, se reinicia desde cero.',
            ].map(item => (
              <li class="flex gap-3 text-slate-600 text-sm leading-relaxed">
                <span class="text-red-400 font-bold mt-0.5 flex-shrink-0">—</span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Con Automata -->
        <div class="bg-white border border-emerald-200 rounded-2xl p-8">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-8 h-8 bg-emerald-100 rounded-lg flex items-center justify-center">
              <span class="text-emerald-600 font-bold text-sm">✓</span>
            </div>
            <h3 class="text-xl font-bold text-slate-900">Con HEB-Automata</h3>
          </div>
          <ul class="space-y-4">
            {[
              'TR.md e IFAO.md generados automáticamente con diagramas Mermaid y matriz de riesgos.',
              'Jerarquía completa Epic → Feature → HU → Tasks creada y publicada en Azure DevOps.',
              'Validación arquitectónica rigurosa en cada gate del flujo.',
              'Escenarios Gherkin traducidos a test cases reales dentro del mismo flujo.',
              'Commits vinculados automáticamente a work items para trazabilidad total.',
              'Reanudación de sesiones interrumpidas desde el punto exacto de parada.',
            ].map(item => (
              <li class="flex gap-3 text-slate-600 text-sm leading-relaxed">
                <span class="text-emerald-500 font-bold mt-0.5 flex-shrink-0">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== COMPONENTES DEL SISTEMA ===== -->
  <section class="bg-white py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-emerald-600 text-sm font-semibold uppercase tracking-widest mb-4">Arquitectura</p>
        <h2 class="text-4xl font-black text-slate-900 mb-4 tracking-tight">Componentes del Sistema</h2>
        <p class="text-slate-600 text-lg max-w-2xl mx-auto">
          Cada sección del sistema cumple una función específica dentro del flujo de automatización.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            href: `${base}/cli`,
            icon: '⌨️',
            color: 'blue',
            title: 'TBA Agent CLI',
            subtitle: 'Instalador multi-plataforma',
            desc: 'Herramienta de línea de comandos que instala y configura el ecosistema completo de agentes y skills en Claude Code, OpenCode o GitHub Copilot.',
          },
          {
            href: `${base}/orquestador`,
            icon: '🧠',
            color: 'purple',
            title: 'TBA Orchestrator',
            subtitle: 'El cerebro del sistema',
            desc: 'Agente principal que coordina el flujo SDD completo, clasificando cada solicitud y delegando a los agentes especializados con validación en cada gate.',
          },
          {
            href: `${base}/agentes`,
            icon: '🤖',
            color: 'amber',
            title: '8 Agentes Especializados',
            subtitle: 'Expertos autónomos',
            desc: 'Desde el análisis de arquitectura hasta la integración con Azure DevOps, cada agente domina una parte específica del proceso de desarrollo.',
          },
          {
            href: `${base}/skills`,
            icon: '⚡',
            color: 'emerald',
            title: '13 Skills de Automatización',
            subtitle: 'Capacidades modulares',
            desc: 'Skills especializados que los agentes invocan para ejecutar tareas concretas: análisis, planificación, implementación, documentación e integración.',
          },
          {
            href: `${base}/flujo-sdd`,
            icon: '🔄',
            color: 'sky',
            title: 'Flujo SDD',
            subtitle: 'Software Development Driven',
            desc: 'Proceso estructurado de análisis → planificación → ejecución paralela (Track A: docs + Track B: código) con gates de validación en cada etapa.',
          },
          {
            href: `${base}/flujo-sdd`,
            icon: '🔗',
            color: 'rose',
            title: 'Integración Azure DevOps',
            subtitle: 'Trazabilidad completa',
            desc: 'Creación automática de work items, carga de documentación al Wiki y vinculación de commits a historias de usuario para trazabilidad total.',
          },
        ].map(card => (
          <a
            href={card.href}
            class="group bg-white border border-slate-200 rounded-2xl p-6 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col"
          >
            <div class="text-3xl mb-4">{card.icon}</div>
            <h3 class="text-slate-900 font-bold text-lg mb-1 group-hover:text-emerald-600 transition-colors">{card.title}</h3>
            <p class="text-slate-500 text-xs font-semibold uppercase tracking-wide mb-3">{card.subtitle}</p>
            <p class="text-slate-600 text-sm leading-relaxed flex-1">{card.desc}</p>
            <div class="mt-4 text-emerald-600 text-sm font-semibold group-hover:gap-2 flex items-center gap-1 transition-all">
              Conocer más <span>&rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CÓMO FUNCIONA ===== -->
  <section class="bg-gradient-to-br from-blue-950 to-slate-900 py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-emerald-400 text-sm font-semibold uppercase tracking-widest mb-4">Proceso</p>
        <h2 class="text-4xl font-black text-white mb-4 tracking-tight">Cómo funciona</h2>
        <p class="text-slate-300 text-lg max-w-2xl mx-auto">
          El flujo completo desde el requerimiento hasta la entrega, ejecutado de forma autónoma.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
        {[
          { num: '01', title: 'Análisis', desc: 'El orquestador lee el PRD y extrae requerimientos con escenarios Gherkin.' },
          { num: '02', title: 'Planificación', desc: 'El arquitecto genera un plan file-by-file respetando la arquitectura del proyecto.' },
          { num: '03', title: 'Docs + Código', desc: 'Track A y Track B se ejecutan en paralelo: documentación e implementación simultáneas.' },
          { num: '04', title: 'Validación', desc: 'Seis gates verifican consistencia, cobertura de pruebas y alineación arquitectónica.' },
          { num: '05', title: 'Entrega', desc: 'Código en rama feature, documentación en Wiki y work items creados en Azure DevOps.' },
        ].map((step, i) => (
          <div class="relative flex flex-col items-center text-center">
            {i < 4 && (
              <div class="hidden md:block absolute top-8 left-[60%] right-0 h-0.5 bg-blue-800 z-0"></div>
            )}
            <div class="relative z-10 w-16 h-16 bg-blue-900 border-2 border-blue-700 rounded-2xl flex items-center justify-center mb-4">
              <span class="text-emerald-400 font-black text-lg">{step.num}</span>
            </div>
            <h3 class="text-white font-bold mb-2">{step.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PLATAFORMAS ===== -->
  <section class="bg-white py-20 border-t border-slate-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-slate-500 text-sm font-semibold uppercase tracking-widest mb-8">Compatible con</p>
      <div class="flex flex-wrap justify-center gap-6">
        {[
          { name: 'Claude Code', by: 'Anthropic', badge: 'Recomendado', color: 'emerald' },
          { name: 'OpenCode', by: 'Open Source', badge: '', color: 'blue' },
          { name: 'GitHub Copilot', by: 'Microsoft', badge: '', color: 'purple' },
        ].map(p => (
          <div class="bg-slate-50 border border-slate-200 rounded-2xl px-8 py-6 text-left min-w-[200px]">
            <div class="font-bold text-slate-900 text-lg">{p.name}</div>
            <div class="text-slate-500 text-sm">{p.by}</div>
            {p.badge && (
              <div class="mt-2 inline-block bg-emerald-100 text-emerald-700 text-xs font-semibold px-2 py-0.5 rounded-full">{p.badge}</div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>

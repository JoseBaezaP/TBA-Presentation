---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'HEB-Automata: Sistema de Automatización Inteligente del Ciclo de Desarrollo de Software',
} = Astro.props;

const pathname = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'Inicio' },
  { href: '/cli', label: 'CLI' },
  { href: '/orquestador', label: 'Orquestador' },
  { href: '/agentes', label: 'Agentes' },
  { href: '/skills', label: 'Skills' },
  { href: '/flujo-sdd', label: 'Flujo SDD' },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — HEB-Automata</title>
  </head>
  <body class="bg-white text-slate-900 font-sans antialiased">

    <!-- Barra de navegación fija -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-blue-950 border-b border-blue-900 shadow-2xl shadow-blue-950/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">

          <!-- Logotipo -->
          <a href="/" class="flex items-center gap-3">
            <div class="w-9 h-9 bg-emerald-500 rounded-xl flex items-center justify-center font-black text-white text-sm shadow-lg shadow-emerald-500/30">
              HA
            </div>
            <div class="flex items-baseline gap-2">
              <span class="text-white font-bold text-lg tracking-tight">HEB-Automata</span>
              <span class="text-emerald-400 text-xs font-semibold border border-emerald-400/40 px-2 py-0.5 rounded-full">
                v1.3.2
              </span>
            </div>
          </a>

          <!-- Navegación escritorio -->
          <nav class="hidden md:flex items-center gap-1">
            {navItems.map(item => (
              <a
                href={item.href}
                class={`px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 ${
                  isActive(item.href)
                    ? 'bg-emerald-500/20 text-emerald-400 font-semibold'
                    : 'text-slate-400 hover:text-white hover:bg-white/10'
                }`}
              >
                {item.label}
              </a>
            ))}
          </nav>
        </div>
      </div>
    </header>

    <!-- Contenido principal -->
    <main class="min-h-screen pt-16">
      <slot />
    </main>

    <!-- Pie de página -->
    <footer class="bg-blue-950 mt-24 border-t border-blue-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-12">

          <div class="md:col-span-2">
            <a href="/" class="flex items-center gap-3 mb-5">
              <div class="w-9 h-9 bg-emerald-500 rounded-xl flex items-center justify-center font-black text-white text-sm">
                HA
              </div>
              <span class="text-white font-bold text-lg">HEB-Automata</span>
            </a>
            <p class="text-slate-400 text-sm leading-relaxed max-w-sm">
              Sistema de automatización inteligente del ciclo de desarrollo de software, diseñado
              para los equipos de tecnología de HEB México.
            </p>
            <div class="flex flex-wrap gap-2 mt-5">
              <span class="bg-blue-900/60 text-slate-300 text-xs px-3 py-1 rounded-full border border-blue-800">Claude Code</span>
              <span class="bg-blue-900/60 text-slate-300 text-xs px-3 py-1 rounded-full border border-blue-800">Azure DevOps</span>
              <span class="bg-blue-900/60 text-slate-300 text-xs px-3 py-1 rounded-full border border-blue-800">Node.js 18+</span>
            </div>
          </div>

          <div>
            <h4 class="text-white font-semibold text-xs uppercase tracking-widest mb-5">Secciones</h4>
            <ul class="space-y-3">
              {navItems.map(item => (
                <li>
                  <a
                    href={item.href}
                    class="text-slate-400 hover:text-emerald-400 text-sm transition-colors duration-200"
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div>
            <h4 class="text-white font-semibold text-xs uppercase tracking-widest mb-5">Información</h4>
            <ul class="space-y-3 text-sm">
              <li class="flex justify-between"><span class="text-slate-500">Versión</span><span class="text-slate-300 font-medium">1.3.2</span></li>
              <li class="flex justify-between"><span class="text-slate-500">Equipo</span><span class="text-slate-300 font-medium">Fulfillment</span></li>
              <li class="flex justify-between"><span class="text-slate-500">TBA</span><span class="text-slate-300 font-medium">Jose Baeza</span></li>
              <li class="flex justify-between"><span class="text-slate-500">Actualizado</span><span class="text-slate-300 font-medium">Abr 2026</span></li>
            </ul>
          </div>
        </div>

        <div class="border-t border-blue-900 pt-8">
          <p class="text-slate-600 text-sm text-center">
            © 2026 HEB México &mdash; Dirección de Tecnología e Ingeniería de Productos. Todos los derechos reservados.
          </p>
        </div>
      </div>
    </footer>

  </body>
</html>
